<style>
*,:before,:after{box-sizing:border-box}
#searchbar:focus,#searchbar:hover{outline:none}
#searchbar:focus{background:#fff;border-bottom:3px solid #222}
#searchbar{font-family:sans-serif;border:0;border-bottom:3px solid #fff;width:100%;font-size:15px;line-height:150%;padding:10px;background:#fff;box-shadow:inset 0 0 3px rgba(0,0,0,.2);border-radius:0}
a{color:#222;text-decoration:none}
body,html,h1,h2,h3,h4,h5,pre{margin:unset;padding:0}
body{font-family:sans-serif;font-weight:500;line-height:110%}
body{font-size:12px;line-height:140%;word-break:break-word;max-width:100%;overflow-x:hidden;overflow-y:hidden}
details.expand{padding:6px;border:2px solid #222}
h1,h2,h3,h4{font-family:monospace}
h1{font-weight:400;font-family:monospace}
h4{font-weight:700;font-size:1.1em}
h5{font-weight:400;text-transform:uppercase}
body{display:flex;flex-direction: column;height:100vh;}
header{background:#fff;line-height:100%;font-size:.9em;box-shadow:0px 0px 14px rgb(0 0 0 / 19%);width:100%;padding-bottom:1em;padding-top:1em;}
main{font-size:clamp(12px,.8vw,1.4rem);line-height:140%;width:100%;margin:auto;overflow-x:hidden;
padding:0 2%;height:100%;overflow-y:scroll;max-height:100%;}
nav{flex:1;display:flex;padding:1em 1%;gap:.5%;}
pre[before]:before{display:block;opacity:.5}
pre{background:#222;color:#fff;padding:6px}
pre{white-space:pre-wrap;font-family:monospace;font-weight:400}
table,tr,td,th{border-collapse:collapse;text-align:left}
table{width:100%;border:0 solid #ddd}
td,th{border:2px solid #fff;border-left:none;border-right:none}
td a{word-break:keep-all}
.example,.output{white-space:pre-wrap}
.example{font-weight:700}
.flex{display:flex}
.flex.column{flex-direction:column}
.hidden{display:none!important}
.item{margin:1em 0}
.output{background:#fff;color:#222}
[before]:before{content:attr(before)}
.expand{font-family:monospace}
.icon{background:#fff;width:40px;}
.icon svg{width:100%;height:100%;padding:7px;}
.description{position:relative;font-family:sans-serif}
.description summary{display:block;cursor:pointer;position:relative;background:white}
.description summary:focus{outline:none}
.description[open]{display:block;animation:open .2s linear}
.description[open] summary{position:absolute;top:0;right:0;padding:3px;font-family:monospace;font-size:90%}
.description[open] #open{display:none}
.description #close{display:none}
.description[open] #close{display:block;}
td a{color:gray}
::-webkit-details-marker{display:none}
@keyframes open {
0%{opacity:0;transform:translateY(-10px)}
100%{opacity:1;transform:translateY(0)}
}

</style>
