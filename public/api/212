    "get_token() {",
    "echo \"TOWER_HOST=http://$1\" > ",
    "  TOWER_HOST=http://$1 \\",
    "    TOWER_USERNAME=$2 \\",
    "    TOWER_PASSWORD=$3 \\",
    "    awx login -f human | sed 's,export ,,g' | tee -a \".${1%%.*}\"",
    "}"
